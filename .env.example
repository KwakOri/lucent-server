# ==============================
# App runtime
# ==============================
NODE_ENV=development
PORT=3001
# Comma-separated allowed origins. Leave empty to disable CORS config.
CORS_ORIGINS=http://localhost:3000

# Frontend redirect base URL (email verification / password reset)
FRONTEND_APP_URL=http://localhost:3000
# Optional fallback used by some auth flows
APP_URL=http://localhost:3000

# Admin email list (comma-separated)
ADMIN_EMAILS=admin@example.com

# ==============================
# Supabase (required)
# ==============================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used for auth client. If omitted, service role key is used as fallback.
SUPABASE_ANON_KEY=your-anon-key
# Optional alternative key name (keep one of these two)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ==============================
# Sendon Kakao Alimtalk
# ==============================
SENDON_ENABLED=true
SENDON_MOCK=true
SENDON_ID=your-sendon-id
SENDON_API_KEY=
SENDON_SEND_PROFILE_ID=your-kakao-send-profile-id
# Optional
SENDON_SDK_PACKAGE=@alipeople/sendon-sdk-typescript

# ==============================
# Kakao address search (optional)
# ==============================
KAKAO_REST_API_KEY=

# ==============================
# SMTP (required only for email sending features)
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@example.com

# ==============================
# Cloudflare R2 (required only for image upload/delete features)
# ==============================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
